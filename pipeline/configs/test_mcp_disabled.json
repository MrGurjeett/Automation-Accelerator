{
  "name": "test-mcp-disabled",
  "version": "3",
  "description": "Test scenario: all MCP flags disabled — pipeline runs purely deterministically",
  "use_mcp_decision": false,
  "use_mcp_retry": false,
  "use_mcp_condition": false,
  "defaults": {
    "feature_name": "TestDeterministic"
  },
  "steps": [
    {
      "name": "detect_excel",
      "label": "Detect Input",
      "inputs": {
        "excel_path": "$input.excel_path"
      }
    },
    {
      "name": "read_excel",
      "label": "Read Excel",
      "inputs": {
        "excel_path": "$steps.detect_excel.data.excel_path"
      }
    },
    {
      "name": "validate",
      "label": "Schema Validation",
      "inputs": {
        "rows": "$steps.read_excel.data.rows"
      },
      "on_failure_step": "recover_validation",
      "on_success_step": "normalize"
    },
    {
      "name": "recover_validation",
      "label": "Recovery: Validation",
      "agent": "mcp_recovery",
      "inputs": {
        "error": "$steps.validate.error",
        "failed_step": "validate",
        "context": "$steps.validate.data",
        "recovery_strategy": "auto"
      },
      "condition": {"exists": "$steps.validate.error"},
      "on_failure": "continue",
      "on_success_step": "normalize"
    },
    {
      "name": "normalize",
      "label": "AI Normalisation",
      "inputs": {
        "validated": "$steps.validate.data.validated"
      },
      "on_failure": "continue"
    },
    {
      "name": "generate",
      "label": "Feature Generation",
      "inputs": {
        "accepted": "$steps.normalize.data.accepted",
        "feature_name": "$input.feature_name",
        "excel_path": "$steps.detect_excel.data.excel_path"
      },
      "on_failure": "continue"
    }
  ]
}
