# Azure OpenAI (chat)
AZURE_OPENAI_ENDPOINT=https://northerntrustqeaopenai.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-openai-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=NTQEA-gpt-4.1

# Azure OpenAI (embeddings) - optional separate resource/key
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://northerntrustqeaopenai.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=<your-embedding-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=NTQEA-text-embedding-3-large

# API version
AZURE_OPENAI_API_VERSION=2024-10-21
