# =============================================================================
# Automation Accelerator — Environment Variables
# =============================================================================
# Copy this file to .env and replace placeholders with real values.
# NEVER commit .env to version control.
# =============================================================================

# ── Project Root ────────────────────────────────────────────────────────────
# Absolute path to the Automation-Accelerator repo root.
# Required when running from outside the project directory (e.g. Neuro-SAN
# agents, Docker, CI, or any context where the working dir != repo root).
# If unset, the framework auto-detects by walking up from source files.
AA_ROOT=C:\workspace\Automation-Accelerator

# ── Azure OpenAI (Chat) ─────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-openai-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name

# ── Azure OpenAI (Embeddings) ───────────────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=<your-embedding-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# ── Azure OpenAI (Version) ──────────────────────────────────────────────────
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_db
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>

# ── Email / SMTP ─────────────────────────────────────────────────────────────
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=<your-email@example.com>
EMAIL_SENDER_PASSWORD=<your-email-password>
